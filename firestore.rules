rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function myEmail() { return request.auth.token.email.lower(); }
    function isMainAdminEmail() { return signedIn() && myEmail() == 'similockdn@gmail.com'; }
    function myUserPath() { return /databases/$(database)/documents/users/$(request.auth.uid); }
    function myUserExists() { return signedIn() && exists(myUserPath()); }
    function myUser() { return get(myUserPath()).data; }
    function isAdmin() { return myUserExists() && myUser().role == 'Admin'; }
    function hasProfile() { return myUserExists() && myUser().role != 'Chưa phân quyền'; }

    // CHUẨN BẢO MẬT: users/{UID Firebase Auth}
    match /users/{uid} {
      allow read: if signedIn();

      // Chỉ email similockdn@gmail.com được tự tạo hồ sơ Admin cho chính UID của mình.
      // Tài khoản khác chỉ được tự tạo hồ sơ chờ phân quyền, KHÔNG được tự gán Admin.
      allow create: if signedIn() && (
        (isMainAdminEmail() && uid == request.auth.uid && request.resource.data.role == 'Admin') ||
        (uid == request.auth.uid
          && request.resource.data.role == 'Chưa phân quyền'
          && request.resource.data.perms is list
          && request.resource.data.perms.size() == 0)
      );

      // Admin đã hợp lệ được phân quyền/sửa user.
      // User thường chỉ được sửa thông tin cá nhân, không được đổi role/perms.
      allow update: if signedIn() && (
        isAdmin() ||
        (isMainAdminEmail() && uid == request.auth.uid && request.resource.data.role == 'Admin') ||
        (uid == request.auth.uid
          && request.resource.data.role == resource.data.role
          && request.resource.data.perms == resource.data.perms)
      );

      allow delete: if isAdmin();
    }

    // Bảng giá vốn: chỉ Admin được đọc/ghi để nhân viên không xem được giá vốn.
    match /costPrices/{id} {
      allow read, write: if isAdmin() || isMainAdminEmail();
    }

    // Dữ liệu ERP: chỉ tài khoản đã có hồ sơ hợp lệ mới truy cập.
    // Email Admin chính được phép khởi tạo hệ thống lần đầu.
    match /{document=**} {
      allow read, write: if signedIn() && (hasProfile() || isMainAdminEmail());
    }
  }
}
